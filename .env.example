# Non-secret AGENT_* knobs for local dev. Nothing loads this file automatically — export via
# your shell or direnv; a copied `.env` is gitignored. Config is layered:
# flags > env (`AGENT_*`) > file (`.agent.toml`) > defaults (see `.rules`).
#
# agent holds NO secrets: the engine needs no API key, and tenancy/auth belong to the hoster
# (guardrail 4). If you find yourself adding a credential here, the change is mis-scoped.

# --- Logging ---
# AGENT_LOG=warn                      # error | warn | info | debug | trace (stderr; stdout is the run result)

# --- Boot (Phase 1) ---
# AGENT_FIRECRACKER=firecracker       # the firecracker binary — a PATH name or an absolute path
# AGENT_KERNEL=artifacts/vmlinux      # uncompressed ELF/PVH guest kernel (`cargo xtask fetch-artifacts`)
# AGENT_ROOTFS=artifacts/rootfs.ext4  # base rootfs image; each boot runs against a fresh copy
# AGENT_MARKER=login:                 # console substring meaning "the guest reached userspace" —
#                                     # tied to the pinned rootfs; change it if you swap the image
