# Copy to .env and fill in. .env is gitignored — never commit real keys.

# Polygon.io — market data (REST). Wired by the `market-data` crate's polygon client.
POLYGON_API_KEY=

# Broker (execution layer — not wired yet, kept here so the shape is known).
# Choose one when we get to the execution milestone. See CLAUDE.md guardrails.
# TRADIER_TOKEN=
# TRADIER_ACCOUNT_ID=
# ALPACA_KEY_ID=
# ALPACA_SECRET_KEY=

# Default to PAPER. Real-money execution must be an explicit, deliberate flip.
EXUB_TRADING_MODE=paper
